{
  "filelist": "filelist.f",
  "output": "-",
  "defines": {
    "STRESS_USE_IN": "1",
    "STRESS_ALT": "0"
  },
  "jobs": 0,
  "no_cache": true,
  "refresh_cache": false,
  "quiet": false,
  "no_log_file": false,
  "top": "stress_top",
  "mode": "check-connect-batch",
  "include_ff": true,
  "connect": {
    "include_ff": true,
    "connect_trace": false,
    "strict_generate": false,
    "checks": [
      {
        "a": "stress_top.probe_in",
        "b": "stress_top.u_spine.u_spine.u_spine.u_spine.u_spine.u_spine.u_spine.u_spine.probe_out",
        "id": "port_port"
      },
      {
        "a": "stress_top.probe_in",
        "b": "stress_top.u_spine.u_spine.u_spine.u_spine.u_spine.u_spine.u_spine.u_spine",
        "id": "port_inst"
      },
      {
        "a": "stress_top.probe_in",
        "b": "stress_top.u_spine.u_spine.u_spine.u_spine.u_spine.u_spine.u_spine.u_spine.probe_out",
        "id": "cross_hierarchy"
      },
      {
        "a": "stress_top.u_missing.probe_in",
        "b": "stress_top.u_spine.u_spine.u_spine.u_spine.u_spine.u_spine.u_spine.u_spine.probe_out",
        "id": "missing_hierarchy"
      }
    ]
